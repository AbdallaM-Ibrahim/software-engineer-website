{
  "name": "software-engineer-website",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "prepare": "lefthook install",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "payload": "tsx node_modules/payload/bin.js",
    "generate:types": "tsx node_modules/payload/bin.js generate:types",
    "generate:importmap": "tsx node_modules/payload/bin.js generate:importmap",
    "seed": "tsx --env-file=.env src/seed.ts",
    "email": "email dev --dir emails --port 3001",
    "email:sync": "tsx --env-file=.env scripts/sync-email-templates.tsx",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui"
  },
