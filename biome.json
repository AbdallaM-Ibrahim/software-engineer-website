{
  "$schema": "https://biomejs.dev/schemas/2.5.5/schema.json",

  "vcs": {
    "enabled": true,
    "clientKind": "git",
    "useIgnoreFile": true
  },

  "files": {
    "includes": [
      "**",
      "!public",
      "!next-env.d.ts",
      "!src/payload-types.ts",
      "!src/app/(payload)/admin/importMap.js",
      "!**/*.svg"
    ]
  },

  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 80,
    "lineEnding": "lf"
  },

  "javascript": {
    "formatter": {
      "quoteStyle": "double",
      "semicolons": "always",
      "trailingCommas": "all",
      "arrowParentheses": "always",
      "bracketSameLine": false
    }
  },

  "css": {
    "parser": {
      "tailwindDirectives": true
    },
    "linter": {
      "enabled": true
    }
  },

  "linter": {
    "enabled": true,
    "rules": {
      "preset": "recommended",
      "correctness": {
        "noUnusedVariables": "warn",
        "noUnusedImports": "error",
        "noUnusedFunctionParameters": "warn",
        "useExhaustiveDependencies": "warn"
      },
      "style": {
        "noNonNullAssertion": "off",
        "useSelfClosingElements": "error",
        "useConst": "error",
        "useTemplate": "error",
        "noParameterAssign": "error",
        "useShorthandFunctionType": "error",
        "noUselessElse": "error"
      },
      "suspicious": {
        "noExplicitAny": "warn",
        "noArrayIndexKey": "off",
        "noDoubleEquals": "error",
        "noConsole": {
          "level": "warn",
          "options": { "allow": ["error", "warn"] }
        }
      },
      "complexity": {
        "useOptionalChain": "error",
        "noUselessFragments": "error"
      },
      "performance": {
        "noDelete": "error"
      }
    }
  },

  "assist": {
    "actions": {
      "source": {
        "organizeImports": "off"
      }
    }
  },

  "overrides": [
    {
      "includes": ["**/*.css"],
      "linter": {
        "rules": {
          "suspicious": { "noUnknownAtRules": "off" }
        }
      }
    },
    {
      "includes": ["scripts/**", "src/seed.ts", "tests/**"],
      "linter": {
        "rules": {
          "suspicious": { "noConsole": "off" }
        }
      }
    }
  ]
}
